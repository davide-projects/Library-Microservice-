    {
      "name": "Resilience Tests",
      "item": [
        {
          "name": "01 — Rate Limiter (book-service)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "const token = pm.environment.get('token');",
                  "const totalRequests = 15;",
                  "",
                  "let ok = 0;",
                  "let rateLimited = 0;",
                  "let errors = 0;",
                  "let completed = 0;",
                  "",
                  "for (let i = 0; i < totalRequests; i++) {",
                  "    pm.sendRequest({",
                  "        url: baseUrl + '/book',",
                  "        method: 'GET',",
                  "        header: { 'Authorization': 'Bearer ' + token }",
                  "    }, (err, res) => {",
                  "        if (err) {",
                  "            errors++;",
                  "        } else if (res.code === 429) {",
                  "            rateLimited++;",
                  "        } else if (res.code === 200) {",
                  "            ok++;",
                  "        }",
                  "        completed++;",
                  "    });",
                  "}",
                  "",
                  "pm.collectionVariables.set('rl_ok', '');",
                  "pm.collectionVariables.set('rl_rateLimited', '');",
                  "pm.collectionVariables.set('rl_errors', '');",
                  "",
                  "const checkDone = setInterval(() => {",
                  "    if (completed >= totalRequests) {",
                  "        clearInterval(checkDone);",
                  "        pm.collectionVariables.set('rl_ok', String(ok));",
                  "        pm.collectionVariables.set('rl_rateLimited', String(rateLimited));",
                  "        pm.collectionVariables.set('rl_errors', String(errors));",
                  "        console.log('Rate Limiter: ' + ok + ' OK, ' + rateLimited + ' 429, ' + errors + ' ERR');",
                  "    }",
                  "}, 100);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const rateLimited = parseInt(pm.collectionVariables.get('rl_rateLimited'), 10);",
                  "const errors = parseInt(pm.collectionVariables.get('rl_errors'), 10);",
                  "",
                  "pm.test('Rate Limited count > 0', () => {",
                  "    pm.expect(rateLimited).to.be.above(0,",
                  "        'Nessuna richiesta limitata. Abbassa limit-for-period in config-repo/ per testare.');",
                  "});",
                  "",
                  "pm.test('No network errors', () => {",
                  "    pm.expect(errors).to.eql(0, 'Errori di connessione: ' + errors);",
                  "});",
                  "",
                  "console.log('RISULTATO: ' + rateLimited + ' richieste limitate su ~15');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/book",
              "host": ["{{baseUrl}}"],
              "path": ["book"]
            },
            "description": "Invia 15 richieste GET al book-service per verificare il Rate Limiter.\n\n**Attenzione**: modifica `config-repo/book-service.yml` impostando `limit-for-period: 3` prima del test."
          }
        },
        {
          "name": "02 — Bulkhead (book-service)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "const token = pm.environment.get('token');",
                  "const concurrency = 15;",
                  "",
                  "let ok = 0;",
                  "let bulkheadFull = 0;",
                  "let errors = 0;",
                  "let completed = 0;",
                  "",
                  "for (let i = 0; i < concurrency; i++) {",
                  "    pm.sendRequest({",
                  "        url: baseUrl + '/book',",
                  "        method: 'GET',",
                  "        header: { 'Authorization': 'Bearer ' + token }",
                  "    }, (err, res) => {",
                  "        if (err) {",
                  "            errors++;",
                  "        } else if (res.code === 503) {",
                  "            bulkheadFull++;",
                  "        } else if (res.code === 200) {",
                  "            ok++;",
                  "        }",
                  "        completed++;",
                  "    });",
                  "}",
                  "",
                  "pm.collectionVariables.set('bh_ok', '');",
                  "pm.collectionVariables.set('bh_bulkheadFull', '');",
                  "pm.collectionVariables.set('bh_errors', '');",
                  "",
                  "const checkDone = setInterval(() => {",
                  "    if (completed >= concurrency) {",
                  "        clearInterval(checkDone);",
                  "        pm.collectionVariables.set('bh_ok', String(ok));",
                  "        pm.collectionVariables.set('bh_bulkheadFull', String(bulkheadFull));",
                  "        pm.collectionVariables.set('bh_errors', String(errors));",
                  "        console.log('Bulkhead: ' + ok + ' OK, ' + bulkheadFull + ' 503, ' + errors + ' ERR');",
                  "    }",
                  "}, 100);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const bulkheadFull = parseInt(pm.collectionVariables.get('bh_bulkheadFull'), 10);",
                  "const errors = parseInt(pm.collectionVariables.get('bh_errors'), 10);",
                  "",
                  "pm.test('Bulkhead Full (503) count > 0', () => {",
                  "    pm.expect(bulkheadFull).to.be.above(0,",
                  "        'Nessun 503 Bulkhead Full. ' +",
                  "        'Abbassa max-concurrent-calls in config-repo/book-service.yml a 2 e riavvia.');",
                  "});",
                  "",
                  "pm.test('No network errors', () => {",
                  "    pm.expect(errors).to.eql(0, 'Errori di connessione: ' + errors);",
                  "});",
                  "",
                  "console.log('RISULTATO: ' + bulkheadFull + ' bulkhead full su ~15');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/book",
              "host": ["{{baseUrl}}"],
              "path": ["book"]
            },
            "description": "Invia 15 richieste CONCORRENTI al book-service per verificare il Bulkhead.\n\n**Attenzione**: modifica `config-repo/book-service.yml` impostando `max-concurrent-calls: 2` e `max-wait-duration: 0` prima del test."
          }
        },
        {
          "name": "03 — Circuit Breaker (loan-service)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const baseUrl = pm.environment.get('baseUrl');",
                  "const token = pm.environment.get('token');",
                  "",
                  "pm.collectionVariables.set('cb_serviceUnavailable', '0');",
                  "pm.collectionVariables.set('cb_ok', '0');",
                  "",
                  "const requests = [",
                  "    { url: baseUrl + '/loans/details', method: 'GET' }",
                  "];",
                  "",
                  "let serviceUnavailable = 0;",
                  "let okCount = 0;",
                  "let completed = 0;",
                  "",
                  "for (let i = 0; i < 8; i++) {",
                  "    pm.sendRequest({",
                  "        url: baseUrl + '/loans/details',",
                  "        method: 'GET',",
                  "        header: { 'Authorization': 'Bearer ' + token }",
                  "    }, (err, res) => {",
                  "        if (!err && res.code === 503) {",
                  "            serviceUnavailable++;",
                  "        } else if (!err && res.code === 200) {",
                  "            okCount++;",
                  "        }",
                  "        completed++;",
                  "    });",
                  "}",
                  "",
                  "const checkDone = setInterval(() => {",
                  "    if (completed >= 8) {",
                  "        clearInterval(checkDone);",
                  "        pm.collectionVariables.set('cb_serviceUnavailable', String(serviceUnavailable));",
                  "        pm.collectionVariables.set('cb_ok', String(okCount));",
                  "        console.log('CB: ' + okCount + ' OK, ' + serviceUnavailable + ' 503');",
                  "    }",
                  "}, 200);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const su = parseInt(pm.collectionVariables.get('cb_serviceUnavailable'), 10);",
                  "const ok = parseInt(pm.collectionVariables.get('cb_ok'), 10);",
                  "",
                  "pm.test('Some requests completed (200 or 503)', () => {",
                  "    pm.expect(ok + su).to.be.above(0);",
                  "});",
                  "",
                  "console.log('RISULTATO CB: ' + ok + ' OK, ' + su + ' 503 Service Unavailable');",
                  "if (su > 0) {",
                  "    console.log('✓ Circuit breaker si è aperto e alcune richieste hanno ricevuto 503');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{baseUrl}}/loans/details",
              "host": ["{{baseUrl}}"],
              "path": ["loans", "details"]
            },
            "description": "Testa il Circuit Breaker di loan-service inviando 8 richieste. Se i servizi downstream non rispondono, alcune riceveranno 503."
          }
        }
      ],
      "description": "Test per i pattern di resilienza: Rate Limiter, Bulkhead e Circuit Breaker."
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "my-secret-token-123",
      "type": "string"
    }
  ]
}
